<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Official NuGet.org feed -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />

    <!-- Azure DevOps public feed for dotnet-eng -->
    <add key="dotnet-eng" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-eng/nuget/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <!-- All packages default to nuget.org -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>

    <!-- Force Microsoft.DotNet.XUnitExtensions to come from dotnet-eng feed -->
    <packageSource key="dotnet-eng">
      <package pattern="Microsoft.DotNet.XUnitExtensions" />
    </packageSource>
  </packageSourceMapping>
</configuration>
