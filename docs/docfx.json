{
  "metadata": [
    {
      "src": [
        {
          "src": "../src/KerckhoffsLabs.Runtime.InteropServices",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "properties": {
        "TargetFramework": "net10.0",
        "Configuration": "Release"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "*.md",
          "toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/kl"
    ],
    "globalMetadata": {
      "_appName": "KerckhoffsLabs.Runtime.InteropServices",
      "_appTitle": "KerckhoffsLabs.Runtime.InteropServices",
      "_appLogoPath": "images/icon.png",
      "_appFaviconPath": "images/favicon.ico",
      "_description": "Platform-native interop types for use at the managed/unmanaged boundary.",
      "_enableSearch": true,
      "_disableContribution": true
    }
  }
}
