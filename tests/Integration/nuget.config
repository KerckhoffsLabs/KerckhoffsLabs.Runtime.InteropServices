<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="local" value="../feed" />
  </packageSources>
  <!-- Repo root maps * -> nuget.org; add the most-specific mapping to the locally packed build. -->
  <packageSourceMapping>
    <packageSource key="local">
      <package pattern="KerckhoffsLabs.Runtime.InteropServices" />
    </packageSource>
  </packageSourceMapping>
</configuration>
